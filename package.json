{
  "name": "legacy-blazor-js-build",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "resolve-version": "node scripts/build/resolve-version.mjs",
    "build:variants": "node scripts/build/build-variants.mjs",
    "build": "node scripts/build/build-all.mjs",
    "test": "node --test \"tests/node/**/*.test.mjs\"",
    "test:smoke": "dotnet test tests/PlaywrightTest/PlaywrightTest.csproj",
    "test:compat": "node scripts/test/run-compat-tests.mjs",
    "readme:compat": "node scripts/test/update-readme-compat.mjs",
    "test:compat:update-readme": "node scripts/test/run-compat-tests.mjs && node scripts/test/update-readme-compat.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@rollup/plugin-babel": "^7.1.0",
    "core-js": "^3.49.0",
    "undici": "^7.16.0",
    "whatwg-fetch": "^3.6.20"
  }
}
