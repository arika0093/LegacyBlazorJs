{
  "name": "legacy-blazor-js-build",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "resolve-version": "node src/build/resolve-version.mjs",
    "resolve-builds": "node src/build/resolve-builds.mjs",
    "build:variants": "node src/build/build-variants.mjs",
    "build": "node src/build/index.mjs",
    "build:quick": "LEGACY_BLAZOR_DISABLE_TERSER=true SKIP_PREBUILD=true BUILD_CHANNEL=current BUILD_TARGET_PROFILES=es5 node src/build/index.mjs",
    "build:quick-prev": "LEGACY_BLAZOR_DISABLE_TERSER=true SKIP_PREBUILD=true BUILD_CHANNEL=preview BUILD_TARGET_PROFILES=es5 node src/build/index.mjs",
    "test:smoke": "node --test tests/ChromeSmokeTest/smoke.test.mjs",
    "test:compat": "node src/run/run-compat-tests.mjs",
    "readme:compat": "node src/run/update-readme-compat.mjs",
    "test:compat:update-readme": "node src/run/run-compat-tests.mjs && node src/run/update-readme-compat.mjs",
    "setup:compat-browser": "node src/run/setup-compat-browser.mjs",
    "readme:status": "node util/update-readme-status.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@webcomponents/custom-elements": "^1.6.0",
    "@webcomponents/template": "^1.5.1",
    "@webcomponents/webcomponentsjs": "^2.8.0",
    "abortcontroller-polyfill": "^1.7.8",
    "core-js": "^3.49.0",
    "mutation-observer": "^1.0.3",
    "undici": "^7.16.0",
    "whatwg-fetch": "^3.6.20"
  }
}
