@page "/counter"

<PageTitle>Interactive Counter</PageTitle>

<section class="content-card">
    <p class="eyebrow">Interactive sample</p>
    <h1>Counter</h1>
    <p>
        This page confirms the app is using Blazor Server interactivity correctly inside the container-hosted sample.
    </p>

    <p class="counter-value" role="status">Current count: @currentCount</p>
    <button class="primary-action" @onclick="IncrementCount">Click me</button>
</section>

@code {
    private int currentCount;

    private void IncrementCount()
    {
        currentCount++;
    }
}
