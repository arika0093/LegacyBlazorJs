@page "/redirect-demo"
@inject NavigationManager Navigation

<PageTitle>Redirect Demo</PageTitle>

<section class="content-card">
    <p class="eyebrow">Navigation sample</p>
    <h1>Redirect demo</h1>
    <p>This page waits briefly, then redirects.</p>
    <p>Redirect target: <code>@targetPath</code></p>
    <p>If nothing happens, <a href="@targetPath">continue manually</a>.</p>
</section>

@code {
    [SupplyParameterFromQuery(Name = "target")]
    public string? Target { get; set; }

    private string targetPath = "/redirect-target";

    protected override void OnParametersSet()
    {
        targetPath = string.IsNullOrWhiteSpace(Target) ? "/redirect-target" : Target;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Task.Delay(1500);
        Navigation.NavigateTo(targetPath);
    }
}
