@page "/"

<PageTitle>LegacyBlazorJs Intro Site</PageTitle>

<section class="hero content-card">
    <h1>Blazor Server for older browsers</h1>
    <p class="lead">
        LegacyBlazorJs rebuilds the official ASP.NET Core
        <a href="https://github.com/dotnet/aspnetcore/tree/main/src/Components/Web.JS">Blazor JavaScript runtime</a> for multiple
        language targets, so a Blazor Server app can keep working on older browsers.
    </p>
    <p>
        Please refer to the
        <a href="https://github.com/arika0093/LegacyBlazorJs">GitHub repository</a>
        for source, automation status, and detailed documentation.
    </p>
</section>

<section class="version-selector content-card">
    <p class="eyebrow">Runtime selector</p>
    <h2>Choose the Blazor Server script</h2>
    <p>Select the runtime to load according to the browser you are using.</p>
    <form class="profile-form" method="get">
        <div class="button-row profile-buttons" role="group" aria-label="Blazor Server runtime selector">
            @foreach (var option in RuntimeOptions)
            {
                <button type="submit"
                        class="@GetButtonClass(option)"
                        name="runtime"
                        value="@option.Value"
                        aria-pressed="@IsSelected(option)">
                    @option.Label
                </button>
            }
        </div>
    </form>
    <p class="profile-note">
        @if (SelectedRuntime.IsAutoDetect)
        {
            <span>AutoDetect is enabled, so <code>LegacyBlazorJs.Loader</code> selects the runtime automatically.</span>
        }
        else
        {
            <span>The selected runtime is loaded from <code>@SelectedRuntime.ScriptPath</code>.</span>
        }
    </p>
</section>

<Interactive />
<LegacyBlazorJs.Loader AutoDetect="@SelectedRuntime.IsAutoDetect" Target="@SelectedRuntime.Target" />

@code {
    [SupplyParameterFromQuery(Name = "runtime")]
    public string? Runtime { get; set; }

    private RuntimeOption SelectedRuntime => ResolveRuntime(Runtime);

    private static IReadOnlyList<RuntimeOption> RuntimeOptions { get; } =
    [
        new("auto", "Auto", null, null, true),
        CreateLegacyRuntime("es5"),
        CreateLegacyRuntime("es2015"),
        CreateLegacyRuntime("es2017"),
        CreateLegacyRuntime("es2018"),
        CreateLegacyRuntime("es2020"),
        CreateLegacyRuntime("es2022")
    ];

    private static RuntimeOption CreateLegacyRuntime(string target) =>
        new(target, target.ToUpperInvariant(), target, $"_content/LegacyBlazorJs/blazor.server.{target}.js", false);

    private static RuntimeOption ResolveRuntime(string? runtime) =>
        RuntimeOptions.FirstOrDefault(option => string.Equals(option.Value, runtime, StringComparison.OrdinalIgnoreCase))
        ?? RuntimeOptions[1];

    private bool IsSelected(RuntimeOption option) =>
        string.Equals(option.Value, SelectedRuntime.Value, StringComparison.Ordinal);

    private string GetButtonClass(RuntimeOption option) =>
        IsSelected(option) ? "primary-action" : "ghost-action";

    private sealed record RuntimeOption(string Value, string Label, string? Target, string? ScriptPath, bool IsAutoDetect);
}
