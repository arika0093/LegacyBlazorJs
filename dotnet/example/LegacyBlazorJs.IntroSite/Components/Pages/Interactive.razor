@rendermode InteractiveServer
@using Microsoft.JSInterop

<section class="feature-grid" id="interactive">
    <article class="feature">
        <p class="eyebrow">Connection</p>
        <h2>Interactive status</h2>
        <p>
            This status changes automatically after the Blazor interactive connection is established.
        </p>
        <p id="@ConnectionStatusElementId"
           class="counter-value @GetConnectionStatusClass()"
           data-connection-status="loading"
           role="status"
           translate="no">
            @GetConnectionStatusText()
        </p>
    </article>

    <article class="feature">
        <p class="eyebrow">Counter</p>
        <h2>Interactive counter</h2>
        <p>
            This counter is rendered through Blazor Server and is intended to keep working on older browsers too.
        </p>
        <p class="counter-value" role="status" translate="no">
            @currentCount
        </p>
        <div class="button-row">
            <button class="primary-action" @onclick="IncrementCount">Increment</button>
            <button class="ghost-action" @onclick="ResetCount">Reset</button>
        </div>
    </article>

    <article class="feature">
        <p class="eyebrow">Redirect</p>
        <h2>Interactive navigation</h2>
        <p>
            Client-side navigation via <code>NavigateTo</code> should also continue to work with the legacy profile.
        </p>
        <button class="secondary-action" @onclick="OpenRedirectDemo">Try Redirect</button>
    </article>
</section>

@inject IJSRuntime JS
@inject NavigationManager Navigation
@code {
    private const string ConnectionStatusElementId = "interactive-connection-status";
    private ConnectionStatus connectionStatus = ConnectionStatus.Loading;
    private int currentCount;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || connectionStatus is ConnectionStatus.Connected)
        {
            return;
        }

        connectionStatus = ConnectionStatus.Connected;
        await JS.InvokeVoidAsync("LegacyBlazorJsIntroSite.interactiveStatus.markConnected", ConnectionStatusElementId);
        StateHasChanged();
    }

    private string GetConnectionStatusText() => connectionStatus switch
    {
        ConnectionStatus.Connected => "Connected",
        ConnectionStatus.Failed => "Failed",
        _ => "Loading..."
    };

    private string GetConnectionStatusClass() => connectionStatus switch
    {
        ConnectionStatus.Connected => "connection-status connection-status-connected",
        ConnectionStatus.Failed => "connection-status connection-status-failed",
        _ => "connection-status connection-status-loading"
    };

    private void IncrementCount()
    {
        currentCount++;
    }

    private void ResetCount()
    {
        currentCount = 0;
    }

    private void OpenRedirectDemo()
    {
        Navigation.NavigateTo("/redirect-target", true);
    }

    private enum ConnectionStatus
    {
        Loading,
        Connected,
        Failed
    }
}
